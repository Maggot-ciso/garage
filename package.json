{
  "name": "garagebook",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "icons": "node scripts/generate-icons.mjs",
    "preview": "vite preview",
    "serve:phone": "vite preview --host",
    "cap:sync": "npm run build:native && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "build:native": "CAP_BUILD=1 npm run build",
    "build:ipa": "bash scripts/build-ipa.sh",
    "build:apk": "bash scripts/build-apk.sh",
    "publish:public": "bash scripts/publish-public.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@capacitor/local-notifications": "^8.2.1",
    "@tailwindcss/vite": "^4.3.2",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.25.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "tailwindcss": "^4.3.2",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
