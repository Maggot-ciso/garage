# Capacitor / iOS — generated; the project itself IS committed so Xcode
# settings and signing config survive, but build output and SPM state are not
ios/App/App/public/
ios/App/build/
ios/App/.swiftpm/
ios/DerivedData/

# Xcode derived data from build-ipa.sh
ios/build/
dist-ipa/

# Android build output (gradle + APK)
android/build/
android/app/build/
android/.gradle/
android/app/src/main/assets/public/
android/local.properties
dist-apk/

# Machine-local build settings (delivery paths etc.)
.env.local

# Local editor/harness config
.claude/
